pragma solidity ^0.8.28;
contract CrowCoin is ERC20, IERC721Receiver {
    // Total supply: 7,777,777 tokens (with 7 decimals: 7,777,777 * 10^7)
    uint256 public constant TOTAL_SUPPLY = 7_777_777 * 10**7;
    
    // Mapping from NFT collection address to rate (tokens per NFT, with 7 decimals)
    mapping(address => uint256) public nftRates;
    
    // Array to track all supported NFT collections
    address[] public supportedCollections;
    
    // Custom errors
    error InvalidCollection();
    error InsufficientBalance();
    error NotNFTOwner();
    error ContractDoesNotOwnNFT();
    error TransferFailed();
    error InvalidAmount();
    
    constructor() ERC20("Crow Coin", "CAWCAW") {
        // Mint total supply to contract itself
        _mint(address(this), TOTAL_SUPPLY);
        
        // Initialize NFT collection rates (with 7 decimals)
        // 1. CRO CROW: 400 tokens = 400 * 10^7
        address croCrow = 0xE4ab77ED89528d90E6bcf0E1Ac99C58Da24e79d5;
        nftRates[croCrow] = 400 * 10**7;
        supportedCollections.push(croCrow);
        
        // 2. CRO CROW NEST: 1700 tokens = 1700 * 10^7
        address croCrowNest = 0x937879726455531dB135F9b8D88F38dF5D4Eb13b;
        nftRates[croCrowNest] = 1700 * 10**7;
        supportedCollections.push(croCrowNest);
        
        // 3. MAD CROW: 400 tokens = 400 * 10^7
        address madCrow = 0x65AB0251d29c9C473c8d01BFfa2966F891fB1181;
        nftRates[madCrow] = 400 * 10**7;
        supportedCollections.push(madCrow);
        
        // 4. 3D CROW: 130 tokens = 130 * 10^7
        address crow3D = 0x3d7777ff1908B54b57038A2556d6904f71468e2D;
        nftRates[crow3D] = 130 * 10**7;
        supportedCollections.push(crow3D);
        
        // 5. CROW PUNK: 288 tokens = 288 * 10^7
        address crowPunk = 0x0f1439A290E86a38157831Fe27a3dCD302904055;
        nftRates[crowPunk] = 288 * 10**7;
        supportedCollections.push(crowPunk);
    }
    
    /**
     * @dev Returns the number of decimals for the token (7 decimals)
     */
    function decimals() public pure override returns (uint8) {
        return 7;
    }
    
    /**
     * @dev Trade NFTs for Crow Coins (sell NFTs)
     * @param collections Array of NFT collection addresses
     * @param tokenIds Array of token IDs to trade (corresponding to collections)
     */
    function buyCAWCAW(
        address[] calldata collections,
        uint256[] calldata tokenIds
    ) external {
        if (collections.length == 0 || collections.length != tokenIds.length) {
            revert InvalidAmount();
        }
        
        uint256 totalTokens = 0;
        
        for (uint256 i = 0; i < collections.length; i++) {
            address collection = collections[i];
            uint256 tokenId = tokenIds[i];
            
            // Check if collection is supported
            if (nftRates[collection] == 0) {
                revert InvalidCollection();
            }
            
            // Check if caller owns the NFT
            IERC721 nft = IERC721(collection);
            if (nft.ownerOf(tokenId) != msg.sender) {
                revert NotNFTOwner();
            }
            
            // Transfer NFT to contract
            nft.transferFrom(msg.sender, address(this), tokenId);
            
            // Add tokens to total
            totalTokens += nftRates[collection];
        }
        
        // Transfer tokens to caller
        if (balanceOf(address(this)) < totalTokens) {
            revert InsufficientBalance();
        }
        
        _transfer(address(this), msg.sender, totalTokens);
    }
    
    /**
     * @dev Trade Crow Coins for NFTs (buy NFTs back)
     * @param collections Array of NFT collection addresses
     * @param tokenIds Array of token IDs to buy (corresponding to collections)
     */
    function sellCAWCAW(
        address[] calldata collections,
        uint256[] calldata tokenIds
    ) external {
        if (collections.length == 0 || collections.length != tokenIds.length) {
            revert InvalidAmount();
        }
        
        uint256 totalTokens = 0;
        
        // Calculate total tokens needed
        for (uint256 i = 0; i < collections.length; i++) {
            address collection = collections[i];
            uint256 tokenId = tokenIds[i];
            
            // Check if collection is supported
            if (nftRates[collection] == 0) {
                revert InvalidCollection();
            }
            
            // Check if contract owns the NFT
            IERC721 nft = IERC721(collection);
            if (nft.ownerOf(tokenId) != address(this)) {
                revert ContractDoesNotOwnNFT();
            }
            
            totalTokens += nftRates[collection];
        }
        
        // Check if caller has enough tokens
        if (balanceOf(msg.sender) < totalTokens) {
            revert InsufficientBalance();
        }
        
        // Transfer tokens from caller to contract
        _transfer(msg.sender, address(this), totalTokens);
        
        // Transfer NFTs to caller
        for (uint256 i = 0; i < collections.length; i++) {
            address collection = collections[i];
            uint256 tokenId = tokenIds[i];
            
            IERC721 nft = IERC721(collection);
            nft.transferFrom(address(this), msg.sender, tokenId);
        }
    }
    
    /**
     * @dev Handles the receipt of an ERC721 token
     * @return bytes4 `bytes4(keccak256("onERC721Received(address,address,uint256,bytes)"))`
     */
    function onERC721Received(
        address,
        address,
        uint256,
        bytes memory
    ) public virtual override returns (bytes4) {
        return this.onERC721Received.selector;
    }
}



